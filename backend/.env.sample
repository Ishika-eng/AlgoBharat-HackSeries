# Copy this file to `.env` in the same directory and fill in real values.
#   cd backend && cp .env.sample .env
# `.env` is gitignored — never commit it.

PORT=5002

# MongoDB Atlas connection string (REQUIRED).
# Get this from Atlas → Database → Connect → Drivers.
# Make sure your Atlas "Network Access" allows your IP (0.0.0.0/0 for demo).
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/CampusTrust?retryWrites=true&w=majority&appName=CampusTrust

# Algorand pool wallet (optional; required for on-chain contribute/borrow/repay).
# Leave blank to run in off-chain fallback mode — the UI will show an
# amber "Off-chain" badge instead of a green "On-chain ✓" badge.
POOL_ADDRESS=
POOL_MNEMONIC=

# Optional: pre-created lending app ID. If blank the backend will try
# to create one on first chain call (requires funded POOL_MNEMONIC).
LENDING_APP_ID=

# Set to 'true' to fail requests instead of falling back off-chain.
BLOCKCHAIN_STRICT=false
